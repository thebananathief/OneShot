<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneShot.Windows.ColorPickerWindow"
        Title="Color Picker"
        Width="420"
        Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="Auto,*" RowSpacing="6" ColumnSpacing="8">
    <TextBlock Grid.Row="0" Grid.Column="0" Text="Preview" VerticalAlignment="Center" />
    <Border x:Name="PreviewBorder" Grid.Row="0" Grid.Column="1" Height="24" BorderBrush="Gray" BorderThickness="1" />

    <TextBlock Grid.Row="1" Grid.Column="0" Text="Hex" VerticalAlignment="Center" />
    <TextBox x:Name="HexText" Grid.Row="1" Grid.Column="1" Text="#FFFF0000" />

    <TextBlock Grid.Row="2" Grid.Column="0" Text="Alpha" VerticalAlignment="Center" />
    <Slider x:Name="AlphaSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" />

    <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette" VerticalAlignment="Top" />
    <Border Grid.Row="3" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="8">
      <WrapPanel x:Name="PalettePanel" />
    </Border>

    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="OkButton" Width="90" Content="OK" />
      <Button x:Name="CancelButton" Width="90" Content="Cancel" />
    </StackPanel>
  </Grid>
</Window>