<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneShot.Windows.SelectionOverlayWindow"
        SystemDecorations="None"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        CanResize="False"
        Cursor="Cross">
  <Grid>
    <Image x:Name="BackgroundImage"
           Stretch="Fill" />
    <Rectangle Fill="#55000000" />
    <Canvas x:Name="RootCanvas">
      <Rectangle x:Name="SelectionRect"
                 IsVisible="False"
                 Stroke="White"
                 StrokeThickness="2"
                 Fill="#33FFFFFF" />
    </Canvas>
  </Grid>
</Window>
