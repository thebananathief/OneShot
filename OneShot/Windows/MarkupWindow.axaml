  </Window.Resources>
  <Window.Styles>
    <Style Selector="Button.icon-button">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>
  <Grid Margin="10" RowDefinitions="Auto,*" RowSpacing="8">
    <WrapPanel Grid.Row="0" VerticalAlignment="Center" ItemHeight="32" Orientation="Horizontal">
      <TextBlock Text="Tool" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox x:Name="ToolCombo" Width="130" Margin="0,0,8,0"/>
      <Button x:Name="OptionsButton"
              Classes="icon-button"
              Margin="0,0,8,0"
              ToolTip.Tip="Options"
              automation:AutomationProperties.Name="Options">
        <PathIcon Width="16" Height="16" Data="{StaticResource settings_regular}" />
      </Button>
      <Popup x:Name="OptionsPopup" Placement="Bottom" PlacementTarget="{Binding #OptionsButton}" IsLightDismissEnabled="True">
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="Gray" BorderThickness="1" Padding="12" MinWidth="340">
          <StackPanel Spacing="8">
            <TextBlock x:Name="OptionsTitle" Text="Options" FontWeight="SemiBold" FontSize="14" />

            <StackPanel x:Name="LineOptionsPanel" Spacing="6">
              <TextBlock Text="Line Size" />
              <Slider x:Name="LineSizeSlider" Minimum="1" Maximum="12" Value="2" Width="280" />
              <TextBlock Text="Line Color" />
              <Button x:Name="LineColorButton" HorizontalAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border x:Name="LineColorSwatch" Width="16" Height="16" BorderBrush="Gray" BorderThickness="1" />
                  <TextBlock x:Name="LineColorText" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>

            <StackPanel x:Name="ShapeOptionsPanel" IsVisible="False" Spacing="6">
              <TextBlock Text="Stroke Size" />
              <Slider x:Name="ShapeStrokeSizeSlider" Minimum="1" Maximum="12" Value="2" Width="280" />
              <TextBlock Text="Stroke Color" />
              <Button x:Name="ShapeStrokeColorButton" HorizontalAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border x:Name="ShapeStrokeColorSwatch" Width="16" Height="16" BorderBrush="Gray" BorderThickness="1" />
                  <TextBlock x:Name="ShapeStrokeColorText" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <TextBlock Text="Fill Opacity" />
              <Slider x:Name="ShapeFillOpacitySlider" Minimum="0" Maximum="1" Value="0.25" Width="280" />
              <TextBlock Text="Fill Color" />
              <Button x:Name="ShapeFillColorButton" HorizontalAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border x:Name="ShapeFillColorSwatch" Width="16" Height="16" BorderBrush="Gray" BorderThickness="1" />
                  <TextBlock x:Name="ShapeFillColorText" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>

            <StackPanel x:Name="TextOptionsPanel" IsVisible="False" Spacing="6">
              <TextBlock Text="Font Family" />
              <ComboBox x:Name="FontCombo" Width="280" />
              <TextBlock Text="Font Size" />
              <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="72" Value="18" Width="280" />
              <TextBlock Text="Font Color" />
              <Button x:Name="TextColorButton" HorizontalAlignment="Left" Padding="8,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Border x:Name="TextColorSwatch" Width="16" Height="16" BorderBrush="Gray" BorderThickness="1" />
                  <TextBlock x:Name="TextColorText" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Popup>

      <Button x:Name="UndoButton"
              Classes="icon-button"
              Margin="0,0,6,0"
              ToolTip.Tip="Undo (Ctrl+Z)"
              automation:AutomationProperties.Name="Undo">
        <PathIcon Width="16" Height="16" Data="{StaticResource arrow_undo_regular}" />
      </Button>
      <Button x:Name="RedoButton"
              Classes="icon-button"
              Margin="0,0,6,0"
              ToolTip.Tip="Redo (Ctrl+Y)"
              automation:AutomationProperties.Name="Redo">
        <PathIcon Width="16" Height="16" Data="{StaticResource arrow_redo_regular}" />
      </Button>
      <Button x:Name="ClipboardButton"
              Classes="icon-button"
              Margin="0,0,6,0"
              ToolTip.Tip="Copy to clipboard"
              automation:AutomationProperties.Name="Copy to clipboard">
        <PathIcon Width="16" Height="16" Data="{StaticResource clipboard_regular}" />
      </Button>
      <Button x:Name="DoneButton"
              Classes="icon-button"
              ToolTip.Tip="Finish and continue"
              automation:AutomationProperties.Name="Done">
        <PathIcon Width="16" Height="16" Data="{StaticResource checkmark_regular}" />
      </Button>
    </WrapPanel>

    <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
      <ScrollViewer x:Name="EditorScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="EditorContainer">
          <LayoutTransformControl x:Name="EditorTransformHost" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid x:Name="EditorSurface">
              <Image x:Name="BaseImage" Stretch="None" />
              <Canvas x:Name="OverlayCanvas" Background="Transparent" />
            </Grid>
          </LayoutTransformControl>
        </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
